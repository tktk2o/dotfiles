#!/bin/bash
# dotfiles pre-commit hook — blocks commits that would leak secrets or
# company-specific terms into this PUBLIC repository.
#
# Scope: enabled only for this repo via `core.hooksPath` (set by setup.sh's
# setup_git_hooks), so it never false-positives on work repos that legitimately
# contain company names.
#
# Two layers:
#   1. Generic secret patterns (below) — safe to keep in this tracked file; the
#      patterns are crafted so they do not match their own source text.
#   2. Company-specific denylist — loaded from a LOCAL, UNTRACKED file so the
#      sensitive terms themselves never land in this public repo:
#         $GIT_DENYLIST_FILE   (default: ~/.config/git/denylist.txt)
#      One `grep -E` (case-insensitive) regex per line; blank lines and lines
#      starting with `#` are ignored.
#
# Bypass (only after manually verifying a false positive): git commit --no-verify

set -u

# Only scan added/modified lines in the staged diff (drop the +++ file headers).
added="$(git diff --cached --unified=0 --no-color | grep -E '^\+' | grep -Ev '^\+\+\+')"
[ -n "$added" ] || exit 0

fail=0
report() { # <label> <matching lines>
    printf '\n\033[31m[pre-commit] BLOCKED: %s\033[0m\n' "$1" >&2
    printf '%s\n' "$2" | sed 's/^/    /' >&2
    fail=1
}

# --- layer 1: generic secrets ---
secret_patterns=(
    'AKIA[0-9A-Z]{16}'                    # AWS access key id
    'ghp_[0-9A-Za-z]{36}'                 # GitHub personal access token
    'github_pat_[0-9A-Za-z_]{50,}'        # GitHub fine-grained PAT
    'gh[oprsu]_[0-9A-Za-z]{30,}'          # other GitHub tokens
    'sk-[A-Za-z0-9]{20,}'                 # OpenAI-style secret key
    'xox[baprs]-[0-9A-Za-z-]{10,}'        # Slack token
    'AIza[0-9A-Za-z_-]{35}'               # Google API key
    '-----BEGIN [A-Z ]+PRIVATE KEY-----'  # private key block
)
for p in "${secret_patterns[@]}"; do
    m="$(printf '%s\n' "$added" | grep -E -- "$p")" || true
    [ -n "$m" ] && report "possible secret matching /$p/" "$m"
done

# --- layer 2: company-specific denylist (local, untracked) ---
denylist="${GIT_DENYLIST_FILE:-$HOME/.config/git/denylist.txt}"
if [ -f "$denylist" ]; then
    while IFS= read -r term; do
        case "$term" in '' | \#*) continue ;; esac
        m="$(printf '%s\n' "$added" | grep -inE -- "$term")" || true
        [ -n "$m" ] && report "company-specific term /$term/" "$m"
    done < "$denylist"
else
    printf '\n\033[33m[pre-commit] WARNING: no company denylist at %s — company-term check skipped\033[0m\n' "$denylist" >&2
fi

if [ "$fail" -ne 0 ]; then
    printf '\nCommit aborted. Remove the flagged content, or use --no-verify if this is a verified false positive.\n' >&2
    exit 1
fi
exit 0
